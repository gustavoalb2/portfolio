# Django Configuration
# =====================
SECRET_KEY=django-insecure-your-secret-key-here
DEBUG=True
VERCEL=False

# Database (Neon) (Neon)
# =====================
# Local: USE_SQLITE=True (padrão quando DEBUG=True)
# Produção (Vercel): USE_SQLITE=False + DATABASE_URL do Neon
# Obtenha a URL em https://console.neon.tech
USE_SQLITE=True
# DATABASE_URL=postgresql://user:password@endpoint.neon.tech/neondb?sslmode=require

# Admin
# =====================
# URL do painel admin (não use "admin/" por segurança)
ADMIN_URL_PATH=painel-secreto/

# Hosts Permitidos
# =====================
# Para desenvolvimento: localhost,127.0.0.1
# Para produção: seu-dominio.vercel.app
ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app,jocelifranco.studio

# Cloudinary (para armazenar imagens na nuvem)
# =====================
# Obtenha em https://cloudinary.com (free tier disponível)
CLOUDINARY_CLOUD_NAME=seu-cloud-name
CLOUDINARY_API_KEY=sua-api-key
CLOUDINARY_API_SECRET=seu-api-secret

# Segurança (Django Security Settings)
# =====================
# Ativar em produção
SECURE_SSL_REDIRECT=False
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_SECURE=False
